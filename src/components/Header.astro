---
import LangSwitcher from "./LangSwitcher.astro";
import type { Locale } from "../layouts/BaseLayout.astro";

interface Props {
  locale: Locale;
  t: any;
  path?: string;
}

const { locale, t, path = "/" } = Astro.props;
const prefix = locale === "uk" ? "" : `/${locale}`;
---

<header class="border-b border-[color:var(--color-parchment-deep)] bg-[color:var(--color-parchment-soft)]/70 backdrop-blur-sm sticky top-0 z-10">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={`${prefix}/`} class="flex items-center gap-3 no-underline group">
      <img
        src="/tur-crest.png"
        alt=""
        width="36"
        height="36"
        class="rounded-full ring-1 ring-[color:var(--color-gold)]/40"
      />
      <div class="leading-tight">
        <div class="font-serif text-base text-[color:var(--color-burgundy)] group-hover:text-[color:var(--color-burgundy-light)] transition">
          {locale === "en" ? "House of Groznov" : locale === "ru" ? "Дом Грозновых" : "Дім Грознових"}
        </div>
        <div class="font-sans text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-gold-deep)]">
          groznov.net
        </div>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-7 font-sans text-sm">
      <a class="no-underline hover:underline" href={`${prefix}/#manifest`}>{t.nav.manifest}</a>
      <a class="no-underline hover:underline" href={`${prefix}/#projects`}>{t.nav.projects}</a>
      <a class="no-underline hover:underline" href={`${prefix}/#tur`}>{t.nav.tur}</a>
      <a class="no-underline hover:underline" href={`${prefix}/#contact`}>{t.nav.contact}</a>
    </nav>

    <LangSwitcher current={locale} path={path} />
  </div>
</header>
