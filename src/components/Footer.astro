---
interface Props { t: any; }
const { t } = Astro.props;
---

<footer class="border-t border-[color:var(--color-parchment-deep)] bg-[color:var(--color-umber)] text-[color:var(--color-parchment)]">
  <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
    <div class="font-sans text-xs uppercase tracking-widest">
      <div>{t.footer.copyright}</div>
      <div class="mt-1 text-[color:var(--color-parchment)]/60">{t.footer.creator}</div>
    </div>
    <div class="font-sans text-[10px] uppercase tracking-widest text-[color:var(--color-parchment)]/50">
      {t.footer.stack}
    </div>
  </div>
</footer>
