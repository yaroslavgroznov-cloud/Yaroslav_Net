---
import type { Locale } from "../layouts/BaseLayout.astro";
interface Props { t: any; locale: Locale; }
const { t, locale } = Astro.props;
const prefix = locale === "uk" ? "" : `/${locale}`;

const projects = [
  { key: "adam",   href: "https://adam.groznov.uk/", external: true,  live: true  },
  { key: "oracle", href: `${prefix}/oracle`,         external: false, live: true  },
  { key: "triada", href: `${prefix}/triada`,         external: false, live: true  },
];
---

<section id="projects" class="scroll-mt-24 bg-[color:var(--color-parchment-deep)]/40">
  <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
    <p class="eyebrow">{t.projects.eyebrow}</p>
    <h2 class="mt-4 font-serif text-4xl md:text-5xl">{t.projects.title}</h2>
    <p class="mt-6 lead max-w-2xl">{t.projects.lead}</p>

    <div class="mt-12 grid md:grid-cols-2 gap-6">
      {projects.map((p) => {
        const item = t.projects.items[p.key];
        const Wrapper = p.href ? "a" : "div";
        return (
          <Wrapper
            href={p.href}
            class="project-card block p-7 no-underline"
            rel={p.external ? "noopener" : undefined}
          >
            <div class="flex items-start justify-between gap-4">
              <h3 class="font-serif text-2xl text-[color:var(--color-burgundy)]">
                {item.name}
              </h3>
              {p.live ? (
                <span class="font-sans text-[10px] uppercase tracking-widest px-2 py-1 bg-[color:var(--color-gold)]/15 text-[color:var(--color-gold-deep)] border border-[color:var(--color-gold)]/30 whitespace-nowrap">
                  LIVE
                </span>
              ) : (
                <span class="font-sans text-[10px] uppercase tracking-widest px-2 py-1 bg-[color:var(--color-ochre)]/15 text-[color:var(--color-ochre-dark)] border border-[color:var(--color-ochre)]/30 whitespace-nowrap">
                  SOON
                </span>
              )}
            </div>
            <p class="mt-2 font-sans text-xs uppercase tracking-widest text-[color:var(--color-sepia)]">
              {item.tag}
            </p>
            <p class="mt-4 text-base leading-relaxed text-[color:var(--color-umber)]">
              {item.desc}
            </p>
            <p class="mt-5 font-sans text-sm text-[color:var(--color-gold-deep)]">
              {item.cta} {p.href ? "→" : ""}
            </p>
          </Wrapper>
        );
      })}
    </div>
  </div>
</section>
