---
interface Props { t: any; }
const { t } = Astro.props;
---

<section id="manifest" class="scroll-mt-24">
  <div class="max-w-3xl mx-auto px-6 py-20 md:py-28">
    <p class="eyebrow">{t.manifest.eyebrow}</p>
    <h2 class="mt-4 font-serif text-4xl md:text-5xl">{t.manifest.title}</h2>

    <div class="mt-10 space-y-7 text-lg md:text-xl leading-relaxed text-[color:var(--color-umber)]">
      <p>{t.manifest.p1}</p>
      <p>{t.manifest.p2}</p>
      <p>{t.manifest.p3}</p>
      <p class="lead">{t.manifest.p4}</p>
    </div>

    <div class="divider mt-14">✦</div>
  </div>
</section>
