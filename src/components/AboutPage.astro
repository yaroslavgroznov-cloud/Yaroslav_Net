---
// AboutPage — визитка Дома. Образец взят с adam.groznov.uk LandingPage:
// «рукописное письмо» — пергамент + охра + бордо, serif italic, центрировано,
// длинный одностраничный scroll, ✦-разделители между секциями.
interface Props { t: any; locale: "uk" | "en" | "ru" }
const { t, locale } = Astro.props;

const localePrefix = locale === "en" ? "" : "/" + locale;

const ab = t.about;

const items = [
  { label: t.contact.press,    value: "press@groznov.net",   href: "mailto:press@groznov.net" },
  { label: t.contact.general,  value: "contact@groznov.net", href: "mailto:contact@groznov.net" },
  { label: t.contact.adam_bot, value: "@AdamGroznovBot",     href: "https://t.me/AdamGroznovBot" },
  { label: t.contact.support,  value: t.contact.support_value, href: localePrefix + "/support" },
];
---

<section id="about" class="bg-[color:var(--color-parchment)]">
  <div class="max-w-6xl mx-auto px-6 pt-12 pb-20 md:pt-20 md:pb-28">

    <div class="page-frame serif-corners p-8 md:p-16 bg-[color:var(--color-parchment-soft)]">

      {/* HERO — большой герб, eyebrow «Визитка», имя Дома, тагляйн.
          Структура повторяет Hero главной (page-frame + центр), tone — Домовой:
          .eyebrow + .lead из global.css, без italic-sepia из Адамова стиля. */}
      <div class="text-center max-w-2xl mx-auto stagger-parent">
        <p class="eyebrow stagger-1">{ab.eyebrow}</p>

        <div class="mt-8 flex justify-center stagger-2">
          <img
            src="/crest-main.png"
            alt={ab.crest_alt}
            width="240"
            height="196"
            class="object-contain crest-glow about-crest"
            style="width: clamp(180px, 30vw, 240px); height: auto;"
            loading="eager"
            draggable="false"
          />
        </div>

        <h1
          class="mt-8 font-serif text-[color:var(--color-burgundy)] leading-[1.05] stagger-3"
          style="font-size: clamp(34px, 7vw, 56px); letter-spacing: 0.04em;"
        >
          {ab.title}
        </h1>

        <p class="mt-6 lead stagger-4">{ab.lead}</p>
      </div>

      <div class="divider mt-16 md:mt-20">✦</div>

      {/* «Вот кто мы» */}
      <section class="max-w-xl mx-auto mt-14 md:mt-16 text-center">
        <p class="eyebrow reveal">{ab.who_label}</p>
        <div class="mt-6 space-y-5 text-[color:var(--color-umber)]" style="font-size: 17px; line-height: 1.75;">
          <p class="reveal" data-reveal-delay="120">{ab.who_p1}</p>
          <p class="opacity-85 reveal" data-reveal-delay="180">{ab.who_p2}</p>
        </div>
      </section>

      <div class="divider mt-14 reveal">✦</div>

      {/* «Вот наш герб» */}
      <section class="max-w-xl mx-auto mt-14 text-center">
        <p class="eyebrow reveal">{ab.crest_label}</p>
        <p
          class="mt-6 text-[color:var(--color-umber)] opacity-90 reveal"
          data-reveal-delay="120"
          style="font-size: 17px; line-height: 1.75;"
        >
          {ab.crest_caption}
        </p>
      </section>

      <div class="divider mt-14 reveal">✦</div>

      {/* «Вот наша почта» */}
      <section class="max-w-xl mx-auto mt-14">
        <p class="eyebrow text-center reveal">{ab.mail_label}</p>
        <ul class="mt-8 space-y-4">
          {items.map((it, i) => (
            <li class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-6 border-b border-[color:var(--color-parchment-deep)] pb-4 reveal reveal--left" data-reveal-delay={120 + i * 80}>
              <span class="font-sans text-xs uppercase tracking-widest text-[color:var(--color-sepia)] min-w-[10rem]">
                {it.label}
              </span>
              <a href={it.href} class="house-link font-serif text-lg md:text-xl no-underline">
                {it.value}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <div class="divider mt-14 reveal">✦</div>

      {/* «Вот наша платформа» — большая CTA-кнопка на adam.groznov.uk */}
      <section class="max-w-xl mx-auto mt-14 text-center">
        <p class="eyebrow reveal">{ab.platform_label}</p>
        <p
          class="mt-6 text-[color:var(--color-umber)] opacity-90 reveal"
          data-reveal-delay="120"
          style="font-size: 17px; line-height: 1.75;"
        >
          {ab.platform_lead}
        </p>
        <a
          href="https://adam.groznov.uk/"
          class="cta-button no-underline mt-10 inline-block px-8 py-4 bg-[color:var(--color-burgundy)] text-[color:var(--color-parchment-soft)] hover:bg-[color:var(--color-burgundy-light)] transition font-sans text-sm tracking-[0.1em] uppercase reveal reveal--scale"
          data-reveal-delay="240"
        >
          {ab.platform_cta} →
        </a>
      </section>

      <p class="mt-16 text-center">
        <a
          href={locale === "uk" ? "/" : "/" + locale + "/"}
          class="font-sans text-xs uppercase tracking-widest text-[color:var(--color-sepia)] hover:text-[color:var(--color-burgundy)]"
        >{ab.back}</a>
      </p>
    </div>
  </div>
</section>

<style>
  .about-crest {
    animation: about-crest-breathe 9s var(--ease-in-out) infinite;
    transform-origin: center;
  }
  @keyframes about-crest-breathe {
    0%, 100% { transform: scale(1)     rotate(0deg); }
    50%      { transform: scale(1.015) rotate(0.4deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .about-crest { animation: none; }
  }
</style>
