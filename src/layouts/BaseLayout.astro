---
import "../styles/global.css";
import uk from "../i18n/uk.json";
import en from "../i18n/en.json";
import ru from "../i18n/ru.json";

export type Locale = "uk" | "en" | "ru";

interface Props {
  locale: Locale;
  pageTitle?: string;
  pageDescription?: string;
  path?: string;
}

const dicts = { uk, en, ru };
const { locale, pageTitle, pageDescription, path = "/" } = Astro.props;
const t = dicts[locale];

const title = pageTitle ?? t.meta.title;
const description = pageDescription ?? t.meta.description;
const canonical = `https://groznov.net${locale === "uk" ? "" : "/" + locale}${path === "/" ? "" : path}`;
const ogLocale =
  locale === "uk" ? "uk_UA" : locale === "ru" ? "ru_RU" : "en_US";

const altUk = `https://groznov.net${path === "/" ? "" : path}`;
const altEn = `https://groznov.net/en${path === "/" ? "" : path}`;
const altRu = `https://groznov.net/ru${path === "/" ? "" : path}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://groznov.net/#org",
      name: "Дом Грозновых",
      alternateName: ["House of Groznov", "Дім Грознових"],
      url: "https://groznov.net/",
      logo: "https://groznov.net/tur-crest.png",
      image: "https://groznov.net/og.jpg",
      description:
        "Дом Грозновых — пространство долгого разговора, родового эха и живых проектов: Адам Грознов, Oracle/Vector/Rupor, Триада IP.",
      sameAs: [
        "https://adam.groznov.uk/",
        "https://github.com/yaroslavgroznov-cloud/Yaroslav_Adam_Web",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://groznov.net/#website",
      url: "https://groznov.net/",
      name: "Дом Грозновых · House of Groznov",
      description,
      publisher: { "@id": "https://groznov.net/#org" },
      inLanguage: ["uk", "en", "ru"],
    },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#2A1F15" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Тема — определяем ДО первого рендера, чтобы не было flash светлой темы
        перед переключением в тёмную. Source-of-truth: localStorage('groznov.theme').
        Три префы: 'auto' (по часу: 19-7 = dark) / 'dark' / 'light'.
        Тот же подход, что useDarkMode на adam.groznov.uk, в vanilla JS для Astro. */}
    <script is:inline>
      (function () {
        var KEY = "groznov.theme";
        var pref = null;
        try { pref = localStorage.getItem(KEY); } catch (_) {}
        if (pref !== "dark" && pref !== "light") pref = "auto";
        var isDark;
        if (pref === "dark") isDark = true;
        else if (pref === "light") isDark = false;
        else {
          var h = new Date().getHours();
          isDark = h >= 19 || h < 7;
        }
        var root = document.documentElement;
        root.setAttribute("data-theme", isDark ? "dark" : "light");
        root.setAttribute("data-theme-pref", pref);
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="uk" href={altUk} />
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="ru" href={altRu} />
    <link rel="alternate" hreflang="x-default" href={altUk} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Дом Грозновых · House of Groznov" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://groznov.net/og.jpg" />
    <meta property="og:image:width" content="880" />
    <meta property="og:image:height" content="480" />
    <meta property="og:image:alt" content="Дом Грозновых · House of Groznov" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content="uk_UA" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="ru_RU" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://groznov.net/og.jpg" />

    <meta name="author" content="Дом Грозновых · House of Groznov" />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- EB Garamond -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* Astro View Transitions — плавный переход между страницами одной локали */}
    <meta name="view-transition" content="same-origin" />

    {/* Scroll-reveal: IntersectionObserver добавляет .is-visible к .reveal элементам.
        Inline script, чтобы избежать FOUC на CSS-only страницах. */}
    <script is:inline>
      (function () {
        if (typeof IntersectionObserver === "undefined") {
          // Старые браузеры — открыть всё сразу
          document.documentElement.classList.add("reveal-fallback");
          return;
        }
        const onReady = function () {
          const els = document.querySelectorAll(".reveal");
          if (!els.length) return;
          const io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  io.unobserve(entry.target);
                }
              });
            },
            { rootMargin: "0px 0px -80px 0px", threshold: 0.08 }
          );
          els.forEach(function (el) { io.observe(el); });
        };
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", onReady);
        } else {
          onReady();
        }
        // Astro view-transition: re-observe после navigation
        document.addEventListener("astro:page-load", onReady);
      })();
    </script>

    {/* Fallback для не-IO браузеров — просто покажем всё */}
    <style is:global>
      .reveal-fallback .reveal {
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
