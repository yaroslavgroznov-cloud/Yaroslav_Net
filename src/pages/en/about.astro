---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import AboutPage from "../../components/AboutPage.astro";
import Footer from "../../components/Footer.astro";
import t from "../../i18n/en.json";

const locale = "en" as const;
const pageTitle = `${t.about_page.title_short} · ${t.meta.title}`;
const pageDescription = t.about_page.description;
---

<BaseLayout
  locale={locale}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  path="/about"
>
  <Header locale={locale} t={t} path="/about" />
  <AboutPage t={t} locale={locale} />
  <Footer t={t} />
</BaseLayout>
