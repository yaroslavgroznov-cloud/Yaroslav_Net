---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import SofRmuPage from "../../components/SofRmuPage.astro";
import Footer from "../../components/Footer.astro";
import t from "../../i18n/en.json";

const locale = "en" as const;
const pageTitle = "SOF RMU Resistance · House of Groznov";
const pageDescription = t.sof_page.sub;
---

<BaseLayout
  locale={locale}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  path="/sof-rmu"
>
  <Header locale={locale} t={t} path="/sof-rmu" />
  <SofRmuPage t={t} locale={locale} />
  <Footer t={t} />
</BaseLayout>
