---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import AnthemPage from "../components/AnthemPage.astro";
import Footer from "../components/Footer.astro";
import t from "../i18n/uk.json";

const locale = "uk" as const;
const pageTitle = `${t.anthem.title} · ${t.meta.title}`;
const pageDescription = t.anthem.lead;
---

<BaseLayout
  locale={locale}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  path="/anthem"
>
  <Header locale={locale} t={t} path="/anthem" />
  <AnthemPage t={t} locale={locale} />
  <Footer t={t} />
</BaseLayout>
