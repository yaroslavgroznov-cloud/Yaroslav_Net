---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import OraclePage from "../components/OraclePage.astro";
import Footer from "../components/Footer.astro";
import t from "../i18n/uk.json";

const locale = "uk" as const;
const pageTitle = "Oracle · Vector · Rupor — Дім Грознових";
const pageDescription = t.oracle_page.sub;
---

<BaseLayout
  locale={locale}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  path="/oracle"
>
  <Header locale={locale} t={t} path="/oracle" />
  <OraclePage t={t} locale={locale} />
  <Footer t={t} />
</BaseLayout>
