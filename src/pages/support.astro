---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import SupportPage from "../components/SupportPage.astro";
import Footer from "../components/Footer.astro";
import t from "../i18n/en.json";

const locale = "en" as const;
const pageTitle = `${t.support_page.title_short} · ${t.meta.title}`;
const pageDescription = t.support_page.description;
---

<BaseLayout
  locale={locale}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  path="/support"
>
  <Header locale={locale} t={t} path="/support" />
  <SupportPage t={t} locale={locale} />
  <Footer t={t} />
</BaseLayout>
