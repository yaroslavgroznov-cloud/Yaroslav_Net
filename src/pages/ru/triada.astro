---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import TriadaPage from "../../components/TriadaPage.astro";
import Footer from "../../components/Footer.astro";
import t from "../../i18n/ru.json";

const locale = "ru" as const;
const pageTitle = `${t.triada_page.title_short} · ${t.meta.title}`;
const pageDescription = t.triada_page.description;
---

<BaseLayout
  locale={locale}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  path="/triada"
>
  <Header locale={locale} t={t} path="/triada" />
  <TriadaPage t={t} locale={locale} />
  <Footer t={t} />
</BaseLayout>
